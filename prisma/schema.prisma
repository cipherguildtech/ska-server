generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum Users_role {
  ADMIN
  STAFF
}

enum Users_dept {
  HR
  SALES
  MARKETING
  DESIGN
  PRODUCTION
  DELIVERY
}

enum Customer_type {
  WALKIN
  REFERRAL
  EXISTING
}

enum Service_type {
  BOARD
  BANNER
  LED
  ROAD_SHOW
  INVITATION
  CARD
}

enum Project_status {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum Task_status {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum Approval_status {
  DRAFT
  SENT
  APPROVED
  REJECTED
}

enum Payment_type {
  ADVANCE
  PARTIAL
  FINAL
}

//////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////

model Users {
  id            String      @id @default(uuid())
  full_name     String
  email         String?     @unique
  phone         String      @unique
  password_hash String
  role          Users_role
  department    Users_dept
  is_active     Boolean     @default(true)

  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  // Relations
  assigned_tasks Tasks[]    @relation("AssignedTasks")
  created_tasks  Tasks[]    @relation("CreatedTasks")
  history_logs   ProjectHistory[]

  @@index([department])
}

//////////////////////////////////////////////////

model Customer {
  id            String         @id @default(uuid())
  name          String
  phone         String
  email         String?
  address       String?
  customer_type Customer_type
  referal String?

  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt

  // Relations
  projects      Projects[]

  @@index([phone])
}

//////////////////////////////////////////////////

model Projects {
  id            String          @id @default(uuid())
  project_code  String          @unique

  customer_id   String
  customer      Customer        @relation(fields: [customer_id], references: [id])

  service_type  Service_type
  description   String

  status        Project_status  @default(ACTIVE)
  current_stage Int             @default(1)

  paid          Decimal         @db.Decimal(10, 2) @default(0)
  balance       Decimal         @db.Decimal(10, 2) @default(0)

  deadline      DateTime

  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt

  // Relations
  tasks         Tasks[]
  quotations    Quotations[]
  payments      Payments[]
  history       ProjectHistory[]

  @@index([customer_id])
  @@index([status])
}

//////////////////////////////////////////////////

model Tasks {
  id            String      @id @default(uuid())

  project_id    String
  project       Projects    @relation(fields: [project_id], references: [id])

  assigned_to   String
  assignee      Users       @relation("AssignedTasks", fields: [assigned_to], references: [id])

  assigned_by   String
  assigner      Users       @relation("CreatedTasks", fields: [assigned_by], references: [id])

  department    Users_dept

  title         String
  notes         String?

  status        Task_status @default(PENDING)

  file          Json?
  history       Json?

  due_at        DateTime
  completed_at  DateTime?

  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  @@index([project_id])
  @@index([assigned_to])
}

//////////////////////////////////////////////////

model Quotations {
  id              String          @id @default(uuid())

  project_id      String
  project         Projects        @relation(fields: [project_id], references: [id])

  amount          Decimal         @db.Decimal(10, 2)
  advance_paid    Decimal?        @db.Decimal(10, 2)

  approval_status Approval_status @default(DRAFT)

  pdf_url         String?

  approved_at     DateTime?

  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  // Relations
  payments        Payments[]

  @@index([project_id])
}

//////////////////////////////////////////////////

model Payments {
  id            String       @id @default(uuid())

  project_id    String
  project       Projects     @relation(fields: [project_id], references: [id])

  quotation_id  String?
  quotation     Quotations?  @relation(fields: [quotation_id], references: [id])

  amount        Decimal      @db.Decimal(10, 2)

  type          Payment_type
  reference     String?

  paid_at       DateTime

  created_at    DateTime     @default(now())

  @@index([project_id])
  @@index([quotation_id])
}

//////////////////////////////////////////////////

model ProjectHistory {
  id          String    @id @default(uuid())

  project_id  String
  project     Projects  @relation(fields: [project_id], references: [id])

  changed_by  String
  user        Users     @relation(fields: [changed_by], references: [id])

  stages      Json?
  statuses    Json?

  note        String?

  changed_at  DateTime  @default(now())

  @@index([project_id])
}